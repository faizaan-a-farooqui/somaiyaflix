<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= moviename %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="header">
        <form method="POST" action="/search" class="search-form">
            <input type="text" name="query" placeholder="Search movies..." required>
            <button type="submit">Search</button>
        </form>

        <% if (user) { %>
            <a href="/account" class="signin-btn" style="text-decoration: underline;">
                <%= user.username %>
            </a>
        <% } else { %>
            <a href="/signin" class="signin-btn">Sign In</a>
        <% } %>
    </div>

    <img
        src="https://i.ibb.co/Qjhb9Smy/somaiyaflix.png"
        alt="SomaiyaFlix"
        class="logo">

    <a href="/" class="action-btn center-btn" style="margin-top: 15px;">
        Back to Trending Movies
    </a>

    <div class="player-buttons">

        <form method="POST" action="/movie">
            <input type="hidden" name="moviename" value="<%= moviename %>">
            <input type="hidden" name="movieid" value="<%= movieid %>">
            <input type="hidden" name="player" value="vidking">
            <button class="player-btn">
                VidKing (Default)
            </button>
        </form>

        <form method="POST" action="/movie">
            <input type="hidden" name="moviename" value="<%= moviename %>">
            <input type="hidden" name="movieid" value="<%= movieid %>">
            <input type="hidden" name="player" value="jw">
            <button class="player-btn">
                JW Player
            </button>
        </form>

        <form method="POST" action="/movie">
            <input type="hidden" name="moviename" value="<%= moviename %>">
            <input type="hidden" name="movieid" value="<%= movieid %>">
            <input type="hidden" name="player" value="vidlink">
            <button class="player-btn">
                VidLink
            </button>
        </form>

    </div>

    <div class="video-container">
        <iframe
            src="<%= playerurl %>"
            allowfullscreen>
        </iframe>
    </div>

</body>
</html>
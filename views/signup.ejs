<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - SomaiyaFlix</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="header">
        <form method="POST" action="/search" class="search-form">
            <input type="text" name="query" placeholder="Search movies..." required>
            <button type="submit">Search</button>
        </form>

        <a href="/" class="signin-btn">Home</a>
    </div>

    <div class="auth-box">

        <img
            src="https://i.ibb.co/Qjhb9Smy/somaiyaflix.png"
            class="logo"
            style="max-width:250px;margin-bottom:20px;"
        >

        <h1>Create Account</h1>

        <% if(typeof error !== "undefined" && error){ %>
            <p class="error"><%= error %></p>
        <% } %>

        <form action="/signup" method="POST" class="auth-form">

            <input
                type="text"
                name="username"
                placeholder="Choose a username"
                minlength="3"
                maxlength="20"
                autocomplete="username"
                required
            >

            <input
                type="password"
                name="password"
                placeholder="Choose a password"
                minlength="6"
                autocomplete="new-password"
                required
            >

            <button type="submit">
                Create Account
            </button>

        </form>

        <a href="/signin" class="action-btn auth-link">
            Already have an account? Sign In
        </a>

    </div>

</body>
</html>
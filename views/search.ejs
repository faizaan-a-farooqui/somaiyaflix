<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results for "<%= query %>"</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #09113f;
            color: #f5f5f5;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #d6d5d8;
        }
        form {
            text-align: center;
            margin-bottom: 30px;
        }
        input[type="text"] {
            padding: 8px;
            border-radius: 4px;
            border: none;
            width: 250px;
        }
        button {
            padding: 8px 12px;
            border-radius: 4px;
            border: none;
            background-color: #00bfff;
            color: #fff;
            cursor: pointer;
        }
        .movies {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 35px;
        }
        .movie-card {
            background: #0e092b;
            width: 150px;
            border-radius: 8px;
            text-align: center;
            padding: 10px;
            border-color: #00bfff;
            border-width: 1px;
            border-style: solid;
        }
        .movie-card img {
            width: 100%;
            border-radius: 6px;
            margin-bottom: 8px;
        }
        a {
            display: block;
            text-align: center;
            color: #00bfff;
            margin-bottom: 20px;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <img src="https://i.ibb.co/Qjhb9Smy/somaiyaflix.png" alt="SomaiyaFlix" border="1" style="display: block; margin: auto;">
    <h1>Search Results for "<%= query %>"</h1>
    <a href="/">Back to Trending Movies</a>

    <form method="POST" action="/search">
        <input type="text" name="query" placeholder="Search movies..." required>
        <button type="submit">Search</button>
    </form>

    <div class="movies">
        <% movies.forEach(movie => { %>
            <form method="POST" action="/movie" style="display:inline-block;">
                <input type="hidden" name="movieid" value="<%= movie.id %>">
                <input type="hidden" name="player" value="jw">
                <button type="submit" style="all:unset; cursor:pointer;">
                    <div class="movie-card">
                        <% if(movie.poster){ %>
                            <img src="<%= movie.poster %>" alt="<%= movie.title %>">
                        <% } %>
                        <div><%= movie.title %> (<%= movie.date %>)</div>
                        <br>
                        <div><%= movie.rating %> ⭐</div>
                    </div>
                </button>
            </form>
        <% }) %>
    </div>
</body>
</html>